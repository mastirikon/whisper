# Длинная случайная строка. Сгенерировать на сервере:
#   docker run --rm python:3.12-slim python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Модель Whisper: tiny | base | small | medium | large-v3 | turbo (= large-v3-turbo)
WHISPER_MODEL=turbo

# Квантизация faster-whisper: int8 | int8_float16 | float16 | float32
# int8 — ~2-4x быстрее fp32 на CPU, RAM в 4 раза меньше, потери качества ≈0.1-0.5% WER
WHISPER_COMPUTE_TYPE=int8

# Устройство инференса: cpu | cuda | auto
WHISPER_DEVICE=cpu

# Максимальный размер загружаемого файла в байтах (по умолчанию 100 МБ)
MAX_CONTENT_LENGTH=104857600
