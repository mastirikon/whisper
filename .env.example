# Длинная случайная строка. Используется для подписи auth-токенов.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Доступ к UI и API. Если пусто — /login и /transcribe вернут 503.
UI_USERNAME=admin
UI_PASSWORD=change-me

# Срок жизни выданного токена в секундах. По умолчанию 30 дней.
AUTH_TOKEN_TTL_SECONDS=2592000

# Модель Whisper: tiny | base | small | medium | large-v3 | turbo (= large-v3-turbo)
WHISPER_MODEL=turbo

# Квантизация faster-whisper: int8 | int8_float16 | float16 | float32
# int8 — ~2-4x быстрее fp32 на CPU, RAM в 4 раза меньше, потери качества ≈0.1-0.5% WER
WHISPER_COMPUTE_TYPE=int8

# Устройство инференса: cpu | cuda | auto
WHISPER_DEVICE=cpu

# Максимальный размер загружаемого файла в байтах (по умолчанию 100 МБ)
MAX_CONTENT_LENGTH=104857600
